# ─── Pubbliche (nel browser, iniziano con VITE_) ──────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Solo server-side su Vercel (NON iniziano con VITE_) ─────────────────────
# Supabase → Project Settings → API → service_role key (non condividere mai)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Resend → API Keys
RESEND_API_KEY=re_...
